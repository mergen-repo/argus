{
  "title": "Argus — Tenant View",
  "uid": "argus-tenant",
  "tags": ["argus", "tenant"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "",
  "fiscalYearStartMonth": 0,
  "weekStart": "",
  "style": "dark",
  "editable": true,
  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "type": "query",
        "label": "Tenant ID",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(argus_http_requests_total, tenant_id)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "annotations": {"list": []},
  "panels": [
    {
      "id": 1,
      "title": "Requests/sec for Tenant",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (tenant_id) (rate(argus_http_requests_total{tenant_id=~\"$tenant_id\"}[1m]))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 2,
      "title": "Error Rate for Tenant (%)",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (tenant_id) (rate(argus_http_requests_total{tenant_id=~\"$tenant_id\",status=~\"5..\"}[5m])) / sum by (tenant_id) (rate(argus_http_requests_total{tenant_id=~\"$tenant_id\"}[5m])) * 100",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "Auth Requests for Tenant by Protocol",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (tenant_id, protocol) (rate(argus_aaa_auth_requests_total{tenant_id=~\"$tenant_id\"}[1m]))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{tenant_id}} / {{protocol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 4,
      "title": "Active Sessions for Tenant",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (tenant_id) (argus_active_sessions{tenant_id=~\"$tenant_id\"})",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
    {
      "id": 5,
      "title": "p95 Latency for Tenant",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, tenant_id) (rate(argus_http_request_duration_seconds_bucket{tenant_id=~\"$tenant_id\"}[5m])))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "p95 {{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    }
  ]
}
