# Argus — Environment Variables

# ── Deployment ──
DEPLOYMENT_MODE=single  # single | cluster
APP_ENV=development     # development | staging | production
APP_PORT=8080
WS_PORT=8081
LOG_LEVEL=info          # debug | info | warn | error

# ── Database ──
DATABASE_URL=postgresql://argus:argus_secret@localhost:5432/argus?sslmode=disable
DATABASE_MAX_CONNS=100
DATABASE_MAX_IDLE_CONNS=25

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNS=50

# ── NATS ──
NATS_URL=nats://localhost:4222
NATS_CLUSTER_ID=argus

# ── Authentication ──
JWT_SECRET=change-me-to-random-64-char-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
AUTH_JWT_REMEMBER_ME_TTL=168h
BCRYPT_COST=12

# ── Password Policy (STORY-068) ──
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SYMBOL=true
PASSWORD_MAX_REPEATING=3
PASSWORD_HISTORY_COUNT=5
PASSWORD_MAX_AGE_DAYS=0          # 0 = no expiry

# ── Account Lockout (STORY-068) ──
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=15m

# ── AAA Engine ──
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_SECRET=change-me-radius-shared-secret
DIAMETER_PORT=3868
DIAMETER_ORIGIN_HOST=argus.local
DIAMETER_ORIGIN_REALM=argus.local
SBA_ENABLED=false
SBA_PORT=8443
SBA_ENABLE_MTLS=false

# === Diameter TLS (optional) ===
# DIAMETER_TLS_ENABLED=true
# DIAMETER_TLS_CERT_PATH=/etc/argus/diameter-server.pem
# DIAMETER_TLS_KEY_PATH=/etc/argus/diameter-server-key.pem
# DIAMETER_TLS_CA_PATH=/etc/argus/diameter-ca.pem

# ── Email (SMTP) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@argus.io
SMTP_PASSWORD=change-me
SMTP_FROM=Argus <noreply@argus.io>

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# ── Storage (S3-compatible) ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=argus-archive
S3_REGION=us-east-1

# ── TLS ──
TLS_CERT_PATH=
TLS_KEY_PATH=
RADSEC_CERT_PATH=
RADSEC_KEY_PATH=

# ── Encryption ──
ENCRYPTION_KEY=  # 32-byte hex key for AES-256-GCM encryption of adapter_config (empty = no encryption in dev)

# ── Rate Limiting (defaults) ──
RATE_LIMIT_DEFAULT_PER_MINUTE=1000
RATE_LIMIT_DEFAULT_PER_HOUR=30000
RATE_LIMIT_ALGORITHM=sliding_window
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_ENABLED=true

# ── Background Jobs (SVC-09) ──
JOB_MAX_CONCURRENT_PER_TENANT=5
JOB_TIMEOUT_MINUTES=30
JOB_TIMEOUT_CHECK_INTERVAL=5m
JOB_LOCK_TTL=60s
JOB_LOCK_RENEW_INTERVAL=30s
CRON_ENABLED=true
CRON_PURGE_SWEEP=@daily
CRON_IP_RECLAIM=@hourly
CRON_SLA_REPORT=@daily

# ── eSIM SM-DP+ Provider ──
ESIM_SMDP_PROVIDER=mock            # mock | generic | valid | thales | idemia | kigen
ESIM_SMDP_BASE_URL=                # e.g. https://smdp.example.com
ESIM_SMDP_API_KEY=
ESIM_SMDP_CLIENT_CERT_PATH=        # path to mTLS client cert PEM
ESIM_SMDP_CLIENT_KEY_PATH=         # path to mTLS client key PEM

# ── SMS Gateway ──
SMS_PROVIDER=                      # "" | twilio | vonage
SMS_ACCOUNT_ID=                    # Twilio AccountSid / Vonage API key
SMS_AUTH_TOKEN=                    # Twilio AuthToken / Vonage API secret
SMS_FROM_NUMBER=                   # e.g. +15005550006
SMS_STATUS_CALLBACK_URL=           # e.g. https://argus.example.com/api/v1/notifications/sms/status
RATE_LIMIT_SMS_PER_MINUTE=10       # per-tenant SMS send rate limit (default: 10)

# ── 5G SBA NRF ──
SBA_NRF_URL=                       # e.g. https://nrf.5gc.example.com (empty = NRF disabled)
SBA_NF_INSTANCE_ID=argus-sba-01   # UUID or stable string identifier for this NF instance
SBA_NRF_HEARTBEAT_SEC=30          # heartbeat interval in seconds

# ── Alerts Retention (FIX-209) ──
ALERTS_RETENTION_DAYS=180              # days to retain rows in the alerts table (min: 30, default: 180)

# ── Roaming Renewal Alerts (STORY-071) ──
ROAMING_RENEWAL_ALERT_DAYS=30          # days before expiry to begin sending renewal alerts
ROAMING_RENEWAL_CRON=0 6 * * *         # cron schedule for renewal sweep (default: daily at 06:00)

# ── Capacity Targets (STORY-070) ──
ARGUS_CAPACITY_SIM=15000000             # total SIM capacity target (display only)
ARGUS_CAPACITY_SESSION=2000000          # max concurrent active session target
ARGUS_CAPACITY_AUTH=5000                # target max auth/s
ARGUS_CAPACITY_GROWTH_SIMS_MONTHLY=72000 # expected net new SIM activations/month

# ── Observability ──
OTEL_EXPORTER_OTLP_ENDPOINT=       # e.g. localhost:4317 (empty = tracing noop)
OTEL_SAMPLER_RATIO=1.0             # TraceIDRatioBased sampler [0.0, 1.0]; 1.0 = sample all
OTEL_SERVICE_NAME=argus
OTEL_SERVICE_VERSION=dev           # override via: $(git describe --tags --always)
OTEL_DEPLOYMENT_ENVIRONMENT=development  # development | staging | production
METRICS_TENANT_LABEL_ENABLED=true  # set false to drop tenant_id label (cardinality kill-switch)
METRICS_ENABLED=true               # set false to skip Prometheus registry entirely
METRICS_NAMESPACE=argus            # vector namespace prefix (reserved for future use)
OTEL_BSP_EXPORT_TIMEOUT_SEC=5      # BatchSpanProcessor export timeout in seconds
