# Argus — Environment Variables

# ── Deployment ──
DEPLOYMENT_MODE=onprem  # onprem | saas
APP_ENV=development     # development | staging | production
APP_PORT=8080
WS_PORT=8081
LOG_LEVEL=info          # debug | info | warn | error

# ── Database ──
DATABASE_URL=postgresql://argus:argus_secret@localhost:5432/argus?sslmode=disable
DATABASE_MAX_CONNS=100
DATABASE_MAX_IDLE_CONNS=25

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNS=50

# ── NATS ──
NATS_URL=nats://localhost:4222
NATS_CLUSTER_ID=argus

# ── Authentication ──
JWT_SECRET=change-me-to-random-64-char-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
AUTH_JWT_REMEMBER_ME_TTL=168h
BCRYPT_COST=12

# ── AAA Engine ──
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_SECRET=change-me-radius-shared-secret
DIAMETER_PORT=3868
DIAMETER_ORIGIN_HOST=argus.local
DIAMETER_ORIGIN_REALM=argus.local
SBA_ENABLED=false
SBA_PORT=8443
SBA_ENABLE_MTLS=false

# ── Email (SMTP) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@argus.io
SMTP_PASSWORD=change-me
SMTP_FROM=Argus <noreply@argus.io>

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# ── Storage (S3-compatible) ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=argus-archive
S3_REGION=us-east-1

# ── TLS ──
TLS_CERT_PATH=
TLS_KEY_PATH=
RADSEC_CERT_PATH=
RADSEC_KEY_PATH=

# ── Encryption ──
ENCRYPTION_KEY=  # 32-byte hex key for AES-256-GCM encryption of adapter_config (empty = no encryption in dev)

# ── Rate Limiting (defaults) ──
RATE_LIMIT_DEFAULT_PER_MINUTE=1000
RATE_LIMIT_DEFAULT_PER_HOUR=30000
RATE_LIMIT_ALGORITHM=sliding_window
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_ENABLED=true
